rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users and their subcollections
    match /users/{userId} {
      allow get, write: if isOwner(userId);
      
      // Profiles subcollection
      match /profile/{profileId} {
        allow get: if isOwner(userId) && isValidId(profileId);
        allow create: if isOwner(userId) && isValidId(profileId) && 
                      request.resource.data.displayName is string &&
                      request.resource.data.displayName.size() <= 100;
        allow update: if isOwner(userId) && isValidId(profileId) && 
                      request.resource.data.displayName is string &&
                      request.resource.data.displayName.size() <= 100;
      }

      // Trip plans subcollection
      match /tripPlans/{planId} {
        allow get: if isOwner(userId) && isValidId(planId);
        allow create, update: if isOwner(userId) && isValidId(planId) && 
                              request.resource.data.lastUpdated is string &&
                              request.resource.data.lastUpdated.size() <= 100;
      }
    }

    // Shared Trip Gallery Rules
    match /tripGallery/{galleryId}/media/{mediaId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && 
                    isValidId(galleryId) && 
                    isValidId(mediaId) && 
                    request.resource.data.uploadedByUid == request.auth.uid;
      allow delete: if isSignedIn() && (
                    resource.data.uploadedByUid == request.auth.uid || 
                    request.auth.token.email == 'avishekmajumderpciu@gmail.com'
                  );
    }
  }
}
